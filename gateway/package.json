{
  "name": "localhost-ai-hub-gateway",
  "version": "1.0.0",
  "description": "API Gateway for localhost-ai-hub",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "rebuild": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts --esm",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "axios": "^1.4.0",
    "ws": "^8.13.0",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/cors": "^2.8.13",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "nodemon": "^2.0.22"
  }
}
