# Environment Variable Configuration Template
# Rename this file to ".env" and update the values as needed.

# General Settings
APP_NAME=AI_Orchestration_System
APP_ENV=development
APP_PORT=3000
APP_HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_orchestration
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# SQLite (if used in addition to PostgreSQL)
SQLITE_DB_PATH=./data/sqlite/ai_orchestration.db

# Authentication and Security
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=3600  # in seconds

# AI Services
SERVICE_1_API_KEY=your_service_1_api_key
SERVICE_2_API_KEY=your_service_2_api_key
SERVICE_3_API_KEY=your_service_3_api_key
SERVICE_4_API_KEY=your_service_4_api_key

# Gateway Configuration
GATEWAY_PORT=4000
GATEWAY_LOG_LEVEL=info

# Dashboard Configuration
DASHBOARD_PORT=8080
DASHBOARD_API_BASE_URL=http://localhost:4000

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# Redis Configuration (if used for task queues or caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Email Configuration (if notifications are supported)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=AI Orchestration System <noreply@example.com>

# Other Services
SERVICE_5_ENDPOINT=http://localhost:5001
SERVICE_6_ENDPOINT=http://localhost:5002
SERVICE_7_ENDPOINT=http://localhost:5003
SERVICE_8_ENDPOINT=http://localhost:5004
SERVICE_9_ENDPOINT=http://localhost:5005
SERVICE_10_ENDPOINT=http://localhost:5006
SERVICE_11_ENDPOINT=http://localhost:5007
SERVICE_12_ENDPOINT=http://localhost:5008

# Debugging and Development
DEBUG=true
WEBPACK_DEV_SERVER_PORT=3001

# Notes:
# - Replace placeholder values with actual configuration details.
# - Ensure sensitive values like passwords and API keys are kept secure.
# - Adjust service endpoints and ports as necessary for your local setup.